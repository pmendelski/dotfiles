#!/usr/bin/env bash
# Tmux pane picker for Claude Code instances.
# [WAIT] marks panes awaiting permission/confirmation — these sort to top.
# Designed to run inside a tmux display-popup.

fzf_bin="${HOME}/.fzf/bin/fzf"
[ -x "$fzf_bin" ] || fzf_bin="fzf"

# Single tmux call: target, shell PID, and display label for every pane.
# Fields are separated by | (tmux disallows | in session/window names).
pane_data=$(tmux list-panes -a \
  -F '#{session_name}:#{window_index}.#{pane_index}|#{pane_pid}|#{session_name}:#{window_name}.#{pane_index}' \
  2>/dev/null)

[ -n "$pane_data" ] || { printf '\n  No panes found\n'; sleep 2; exit 0; }

# Single ps call
ps_out=$(ps -A -o pid=,ppid=,comm= 2>/dev/null)

# Single awk call: find pane targets where 'claude' is in the process subtree.
# Outputs "target|display_info" for each match (deduped — one claude per pane).
# Phase 0 (before ---): pane_data  — pipe-delimited: target|pid|display
# Phase 1 (after ---):  ps output  — space-delimited: pid ppid comm
claude_panes=$(printf '%s\n---\n%s\n' "$pane_data" "$ps_out" | awk '
  BEGIN { FS=" " }
  /^---$/ { phase=1; next }
  phase == 0 {
    n = split($0, f, "|")
    if (n >= 3) { pane_of[f[2]]=f[1]; display_of[f[2]]=f[3] }
  }
  phase == 1 { parent[$1]=$2; cmd[$1]=$3 }
  END {
    for (pid in cmd) {
      if (cmd[pid] !~ /claude/) continue
      cur = parent[pid]
      for (i = 0; i < 15; i++) {
        if (cur == "" || cur == "0" || cur == "1") break
        if (cur in pane_of && !(pane_of[cur] in seen)) {
          seen[pane_of[cur]] = 1
          print pane_of[cur] "|" display_of[cur]
          break
        }
        cur = parent[cur]
      }
    }
  }
')

if [ -z "$claude_panes" ]; then
  printf '\n  No Claude panes found\n'
  sleep 2
  exit 0
fi

lines=()

# Only capture-pane for the (small) set of detected Claude panes
while IFS='|' read -r target display_info; do
  [ -n "$target" ] || continue

  # Capture only the visible terminal area (no scrollback) so that historical
  # output — diffs, logs, code — can't trigger a false [WAIT] match.
  # Then restrict to the last 10 lines, where interactive prompts always sit.
  content=$(tmux capture-pane -t "$target" -p 2>/dev/null) || continue

  priority=1
  badge=""
  if printf '%s' "$content" | tail -10 | \
     grep -qE "allow once|allow always|\(Y\)es|\(N\)o|↑↓ to move|❯ Yes|❯ No"; then
    priority=0
    badge="[WAIT] "
  fi

  lines+=("${priority}"$'\t'"${badge}${display_info}"$'\t'"${target}")
done <<< "$claude_panes"

if [ ${#lines[@]} -eq 0 ]; then
  printf '\n  No Claude panes found\n'
  sleep 2
  exit 0
fi

selected=$(printf '%s\n' "${lines[@]}" | sort | cut -f2- | "$fzf_bin" \
  --delimiter=$'\t' \
  --with-nth=1 \
  --header='Claude panes  ╱  [WAIT] = needs attention  ╱  C-/ preview' \
  --color='header:italic' \
  --preview='tmux capture-pane -ep -t {2} -S -50' \
  --preview-window='right:60%:wrap' \
  --bind='ctrl-/:change-preview-window(down|hidden|right)' \
  --ansi \
  --layout=reverse \
  --height=100%
) || exit 0

target=$(printf '%s' "$selected" | cut -f2)
[ -z "$target" ] && exit 0

tmux switch-client -t "$target" 2>/dev/null || tmux select-pane -t "$target"
