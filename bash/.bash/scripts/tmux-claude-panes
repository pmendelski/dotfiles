#!/usr/bin/env bash
# Tmux pane picker for AI assistant CLIs (Claude Code, Gemini CLI).
# [WAIT] marks panes awaiting permission/confirmation.
# Within each tier panes sort by most recent activity (newest first).
# Designed to run inside a tmux display-popup.
#
# --jump  Skip the picker: switch to the first [WAIT] pane, or if none,
#         to the most recently finished idle pane.

jump_mode=false
[ "${1:-}" = "--jump" ] && jump_mode=true

fzf_bin="${HOME}/.fzf/bin/fzf"
[ -x "$fzf_bin" ] || fzf_bin="fzf"

# Single tmux call: target, shell PID, display label, last-activity timestamp.
# Fields separated by | (tmux disallows | in session/window names).
pane_data=$(tmux list-panes -a \
  -F '#{session_name}:#{window_index}.#{pane_index}|#{pane_pid}|#{session_name}:#{window_name}.#{pane_index}|#{window_activity}' \
  2>/dev/null)

[ -n "$pane_data" ] || { printf '\n  No panes found\n'; sleep 2; exit 0; }

# Single ps call
ps_out=$(ps -A -o pid=,ppid=,comm= 2>/dev/null)

# Single awk call: find panes with claude or gemini in the process subtree.
# Outputs "target|display|activity|ai_type" per pane (deduped).
# Phase 0 (before ---): pane_data  — pipe-delimited: target|pid|display|activity
# Phase 1 (after ---):  ps output  — space-delimited: pid ppid comm
ai_panes=$(printf '%s\n---\n%s\n' "$pane_data" "$ps_out" | awk '
  BEGIN { FS=" " }
  /^---$/ { phase=1; next }
  phase == 0 {
    n = split($0, f, "|")
    if (n >= 4) {
      pane_of[f[2]]=f[1]; display_of[f[2]]=f[3]; activity_of[f[2]]=f[4]
    }
  }
  phase == 1 { parent[$1]=$2; cmd[$1]=$3 }
  END {
    for (pid in cmd) {
      if (cmd[pid] !~ /claude|gemini/) continue
      ai = (cmd[pid] ~ /claude/) ? "claude" : "gemini"
      cur = parent[pid]
      for (i = 0; i < 15; i++) {
        if (cur == "" || cur == "0" || cur == "1") break
        if (cur in pane_of && !(pane_of[cur] in seen)) {
          seen[pane_of[cur]] = 1
          print pane_of[cur] "|" display_of[cur] "|" activity_of[cur] "|" ai
          break
        }
        cur = parent[cur]
      }
    }
  }
')

if [ -z "$ai_panes" ]; then
  printf '\n  No AI panes found\n'
  sleep 2
  exit 0
fi

now=$(date +%s)
lines=()

while IFS='|' read -r target display_info activity_time ai_type; do
  [ -n "$target" ] || continue

  # Capture only the visible terminal area; check the last 10 lines for prompts
  content=$(tmux capture-pane -t "$target" -p 2>/dev/null) || continue

  priority=1
  badge=""
  # Claude Code: permission prompt options
  pat_claude='allow once|allow always|\(Y\)es|\(N\)o|↑↓ to move|❯ [0-9. ]*Yes|❯ [0-9. ]*No'
  # Gemini CLI: tune these once you see what Gemini actually outputs when waiting
  pat_gemini='\[Y/n\]|\[y/N\]|\[y/n\]|Do you want to proceed|Press y to'
  if printf '%s' "$content" | tail -10 | grep -qE "${pat_claude}|${pat_gemini}"; then
    priority=0
    badge="[WAIT] "
  fi

  elapsed=$(( now - activity_time ))
  [ "$elapsed" -lt 0 ] && elapsed=0
  if   [ "$elapsed" -lt 60 ];   then ago="${elapsed}s"
  elif [ "$elapsed" -lt 3600 ]; then ago="$(( elapsed / 60 ))m"
  else                               ago="$(( elapsed / 3600 ))h"
  fi

  # Line format: priority TAB activity_time TAB display TAB target
  lines+=("${priority}"$'\t'"${activity_time}"$'\t'"${badge}${display_info}  ${ago}"$'\t'"${target}")
done <<< "$ai_panes"

if [ ${#lines[@]} -eq 0 ]; then
  printf '\n  No AI panes found\n'
  sleep 2
  exit 0
fi

sorted=$(printf '%s\n' "${lines[@]}" | sort -t$'\t' -k1,1n -k2,2rn)

# --jump: switch to first [WAIT] pane, or most recently finished idle pane
if $jump_mode; then
  target=$(printf '%s\n' "$sorted" | head -1 | cut -f4)
  [ -n "$target" ] && { tmux switch-client -t "$target" 2>/dev/null || tmux select-pane -t "$target"; }
  exit 0
fi

selected=$(printf '%s\n' "$sorted" | cut -f3- | "$fzf_bin" \
  --delimiter=$'\t' \
  --with-nth=1 \
  --header='AI panes  ╱  C-/ layout  ╱  S-↑↓ scroll  ╱  C-f/b page' \
  --color='header:italic' \
  --preview='tmux capture-pane -ep -t {2} -S -50 | tail -$FZF_PREVIEW_LINES' \
  --preview-window='right:60%:wrap' \
  --bind='ctrl-/:change-preview-window(down|hidden|right)' \
  --bind='shift-up:preview-up,shift-down:preview-down' \
  --bind='ctrl-f:preview-page-down,ctrl-b:preview-page-up' \
  --ansi \
  --layout=reverse \
  --height=100%
) || exit 0

target=$(printf '%s' "$selected" | cut -f2)
[ -z "$target" ] && exit 0

tmux switch-client -t "$target" 2>/dev/null || tmux select-pane -t "$target"
